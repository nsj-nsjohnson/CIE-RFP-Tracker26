  `;
 
  const panel = document.getElementById("panel");
  if (activeTab === "rfps") panel.innerHTML = panelRfps();
  else if (activeTab === "programs") panel.innerHTML = panelPrograms();
  else if (activeTab === "portals") panel.innerHTML = panelPortals();
  else if (activeTab === "aggregators") panel.innerHTML = panelAggregators();
  else if (activeTab === "cbo") panel.innerHTML = panelCbo();
}
 
