<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>CIE &amp; Closed-Loop Referral RFP Tracker</title>
<meta name="description" content="State, county, local, and CBO/foundation RFPs for Community Information Exchange and closed-loop referral platforms." />
<style>
  :root { color-scheme: light; }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    background: #fafaf7;
    color: #1f1f1f;
    line-height: 1.45;
    font-size: 14px;
  }
  .wrap { max-width: 1200px; margin: 0 auto; padding: 22px 26px 80px; }
  h1 { font-size: 24px; margin: 0 0 4px; font-weight: 600; }
  .sub { color: #5d5d5d; font-size: 13px; margin-bottom: 14px; }
  .keywords-banner {
    background: #fef5e9;
    border: 1px solid #f5e0c7;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 12px;
    color: #6b4818;
    margin-bottom: 14px;
  }
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 16px; }
  .stat {
    background: #fff;
    border: 1px solid #e6e3dc;
    border-radius: 10px;
    padding: 12px 16px;
  }
  .stat .num { font-size: 24px; font-weight: 600; }
  .stat .lbl { font-size: 11px; color: #6b6b6b; text-transform: uppercase; letter-spacing: 0.04em; margin-top: 2px; }
  .stat.open { border-left: 4px solid #2f6b3a; }
  .stat.open .num { color: #2f6b3a; }
  .stat.watch { border-left: 4px solid #b85a1c; }
  .stat.watch .num { color: #b85a1c; }
  .stat.awarded { border-left: 4px solid #2e4a85; }
  .stat.awarded .num { color: #2e4a85; }
  .controls { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 12px; background: #fff; border: 1px solid #e6e3dc; border-radius: 10px; padding: 11px 14px; }
  .controls label { font-size: 12px; color: #555; display: flex; gap: 6px; align-items: center; }
  .controls select, .controls input { font: inherit; border: 1px solid #d6d2c9; border-radius: 6px; padding: 5px 8px; background: #fff; color: #1f1f1f; }
  .controls input[type="search"] { min-width: 220px; }
  .tabs { display: flex; gap: 0; margin-bottom: 0; border-bottom: 1px solid #e1ddd3; flex-wrap: wrap; }
  .tab { padding: 9px 14px; cursor: pointer; border: none; background: transparent; font: inherit; color: #666; border-bottom: 2px solid transparent; margin-bottom: -1px; font-size: 13px; }
  .tab.active { color: #b85a1c; border-bottom-color: #b85a1c; font-weight: 600; }
  .tab .count { display: inline-block; margin-left: 6px; background: #f1ede2; color: #555; border-radius: 10px; padding: 1px 8px; font-size: 11px; }
  .tab.active .count { background: #fbe2cf; color: #b85a1c; }
  .panel { background: #fff; border: 1px solid #e6e3dc; border-top: none; border-radius: 0 0 10px 10px; padding: 0; min-height: 220px; }
 
  /* Status section headers */
  .status-section { padding: 14px 18px 6px; }
  .status-section.open-section { background: #f4faf5; border-bottom: 1px solid #e1ecdf; }
  .status-section.watch-section { background: #fef9f1; border-bottom: 1px solid #f0e5d0; }
  .status-section.awarded-section { background: #f3f6fc; border-bottom: 1px solid #d8e1f0; }
  .status-section.closed-section { background: #f7f5f5; border-bottom: 1px solid #e8e2e2; }
  .status-header { display: flex; align-items: center; gap: 10px; margin: 0 0 8px; }
  .status-header h3 { margin: 0; font-size: 15px; font-weight: 600; }
  .status-header.open h3 { color: #2f6b3a; }
  .status-header.watch h3 { color: #b85a1c; }
  .status-header.awarded h3 { color: #2e4a85; }
  .status-header.closed h3 { color: #7a4646; }
  .status-header .badge { font-size: 11px; background: #fff; padding: 2px 9px; border-radius: 999px; font-weight: 500; }
  .status-header.open .badge { color: #2f6b3a; border: 1px solid #2f6b3a; }
  .status-header.watch .badge { color: #b85a1c; border: 1px solid #b85a1c; }
  .status-header.awarded .badge { color: #2e4a85; border: 1px solid #2e4a85; }
  .status-header.closed .badge { color: #7a4646; border: 1px solid #7a4646; }
  .status-header .blurb { font-size: 12px; color: #777; flex: 1; }
 
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 10px 14px; border-bottom: 1px solid #efece4; vertical-align: top; font-size: 13px; }
  th { background: #f7f4eb; font-weight: 600; color: #555; font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #fdfcf6; }
 
  .pill { display: inline-block; padding: 2px 9px; border-radius: 999px; font-size: 11px; font-weight: 500; white-space: nowrap; }
  .pill-state { background: #e9f5ec; color: #1d6b3a; }
  .pill-county { background: #fdf3e7; color: #9b5410; }
  .pill-local { background: #fdf3e7; color: #9b5410; }
  .pill-cbo { background: #f0ecff; color: #4a3a8a; }
  .pill-foundation { background: #fef5d8; color: #856b0e; }
  .pill-keyword { background: #f5f0fb; color: #5a3f8a; font-size: 10px; }
 
  a { color: #b85a1c; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .empty { padding: 28px; text-align: center; color: #888; font-size: 13px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(310px, 1fr)); gap: 11px; padding: 14px; }
  .card { background: #fff; border: 1px solid #e8e4d9; border-radius: 8px; padding: 12px 14px; }
  .card h4 { margin: 0 0 5px; font-size: 13px; }
  .card .pillrow { margin: 5px 0 7px; display: flex; gap: 4px; flex-wrap: wrap; }
  .card .desc { font-size: 12px; color: #555; line-height: 1.45; }
  .last-update { font-size: 11px; color: #888; margin-top: 16px; text-align: right; }
  .quick-search-list { padding: 14px; }
  .quick-search-list .qs { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border: 1px solid #ebe6db; border-radius: 8px; margin-bottom: 6px; background: #fff; }
  .quick-search-list .qs:hover { border-color: #d4cdb9; background: #fefcf6; }
  .qs .label { flex: 1; font-size: 13px; }
  .qs .meta { font-size: 11px; color: #888; }
 
  .deadline-cell { white-space: nowrap; }
  .deadline-soon { color: #a02525; font-weight: 600; }
  .deadline-warn { color: #8d5a14; font-weight: 500; }
  .deadline-future { color: #2f6b3a; font-weight: 500; }
  .deadline-passed { color: #888; }
 
  .priority-flag {
    display: inline-block;
    background: #b85a1c;
    color: #fff;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px 7px;
    border-radius: 4px;
    margin-left: 6px;
    font-weight: 600;
  }
 
  .footer { margin-top: 24px; padding-top: 14px; border-top: 1px solid #e6e3dc; font-size: 12px; color: #888; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .footer a { color: #888; }
</style>
</head>
<body>
<div class="wrap">
  <h1>CIE &amp; Closed-Loop Referral RFP Tracker</h1>
  <div class="sub">State, county, local, and CBO/foundation procurements for Community Information Exchange and closed-loop referral platforms.</div>
 
  <div class="keywords-banner">
    <strong>Tracking keywords:</strong> "community information exchange" / CIE • "closed loop referral" / closed-loop referral platform • community resource referral platform
  </div>
 
  <div class="stats" id="stats"></div>
 
  <div class="controls">
    <label>Search <input type="search" id="q" placeholder="title, state, agency..." /></label>
    <label>Type
      <select id="scope">
        <option value="all">All types</option>
        <option value="state">State</option>
        <option value="county">County / local</option>
        <option value="cbo">CBO / nonprofit</option>
        <option value="foundation">Foundation</option>
      </select>
    </label>
    <label>State
      <select id="stateFilter">
        <option value="all">All states</option>
      </select>
    </label>
    <label><input type="checkbox" id="hideClosed" /> Hide closed</label>
  </div>
 
  <div class="tabs">
    <button class="tab active" data-panel="rfps">RFPs <span class="count" id="cnt-rfps">…</span></button>
    <button class="tab" data-panel="programs">State programs to watch <span class="count" id="cnt-programs">…</span></button>
    <button class="tab" data-panel="portals">Procurement portals <span class="count" id="cnt-portals">…</span></button>
    <button class="tab" data-panel="aggregators">Aggregator searches <span class="count" id="cnt-agg">…</span></button>
    <button class="tab" data-panel="cbo">CBO funders &amp; intermediaries <span class="count" id="cnt-cbo">…</span></button>
  </div>
  <div class="panel" id="panel"><div class="empty">Loading…</div></div>
 
  <div class="footer">
    <div id="last-update"></div>
    <div>
      <a href="https://github.com/" id="repo-link">View source on GitHub</a> &nbsp;·&nbsp;
      Updates curated manually from a daily scan
    </div>
  </div>
</div>
 
<script>
let activeTab = "rfps";
let DATA = { rfps: [], programs: [], portals: [], aggregators: [], cbo: [] };
const STORE_KEY = "cieTrackerPrefs.v4";
const prefs = (() => {
  try { return JSON.parse(localStorage.getItem(STORE_KEY)) || {}; } catch (e) { return {}; }
})();
function savePrefs() { try { localStorage.setItem(STORE_KEY, JSON.stringify(prefs)); } catch (e) {} }
 
document.getElementById("q").value = prefs.q || "";
document.getElementById("scope").value = prefs.scope || "all";
document.getElementById("hideClosed").checked = prefs.hideClosed !== false;
 
["q", "scope", "stateFilter"].forEach(id => {
  document.getElementById(id).addEventListener("input", () => {
    prefs[id] = document.getElementById(id).value; savePrefs(); render();
  });
});
document.getElementById("hideClosed").addEventListener("change", (e) => {
  prefs.hideClosed = e.target.checked; savePrefs(); render();
});
 
document.querySelectorAll(".tab").forEach(t => {
  t.addEventListener("click", () => {
    document.querySelectorAll(".tab").forEach(x => x.classList.remove("active"));
    t.classList.add("active");
    activeTab = t.dataset.panel;
    render();
  });
});
 
function escapeHtml(s) {
  return String(s == null ? "" : s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}
function fmtDate(s) {
  if (!s) return "—";
  const d = new Date(s);
  if (isNaN(d)) return s;
  return d.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
}
function fmtMonth(s) {
  if (!s) return "—";
  if (typeof s === "string" && s.includes("Q")) return s; // already a quarter
  const d = new Date(s);
  if (isNaN(d)) return s;
  return d.toLocaleDateString(undefined, { year: "numeric", month: "short" });
}
function daysUntil(s) {
  if (!s) return null;
  const d = new Date(s);
  if (isNaN(d)) return null;
  return Math.round((d - new Date()) / (1000 * 60 * 60 * 24));
}
function matchQuery(parts, q) {
  if (!q) return true;
  const hay = parts.filter(Boolean).join(" ").toLowerCase();
  return hay.includes(q.toLowerCase());
}
 
function getDeadlineCell(r) {
  // For OPEN: show actual deadline with urgency color
  if (r.status === "open") {
    const d = daysUntil(r.due);
    let cls = "deadline-future";
    if (d == null) return `<span class="deadline-passed">TBD</span>`;
    if (d < 0) cls = "deadline-passed";
    else if (d <= 14) cls = "deadline-soon";
    else if (d <= 45) cls = "deadline-warn";
    return `<span class="${cls}">${fmtDate(r.due)}${d != null ? ` <small>(${d >= 0 ? d + " days" : "passed"})</small>` : ""}</span>`;
  }
  // For WATCH: show expected RFI/RFP timing
  if (r.status === "watch") {
    const lines = [];
    if (r.expected_rfi) lines.push(`<small style="color:#888">RFI exp.</small> ${escapeHtml(r.expected_rfi)}`);
    if (r.expected_rfp) lines.push(`<small style="color:#888">RFP exp.</small> ${escapeHtml(r.expected_rfp)}`);
    return lines.length ? lines.join("<br/>") : `<span class="deadline-passed">TBD</span>`;
  }
  // For AWARDED: show award date
  if (r.status === "awarded") {
    return r.awarded_date ? `<small style="color:#888">Awarded</small> ${escapeHtml(r.awarded_date)}` : `<span class="deadline-passed">—</span>`;
  }
  // For CLOSED: show due date if known
  if (r.status === "closed") {
    return r.due ? `<small style="color:#888">Closed</small> ${fmtDate(r.due)}` : `<span class="deadline-passed">—</span>`;
  }
  return `<span class="deadline-passed">—</span>`;
}
 
function rfpRow(r) {
  let valueLine = "";
  if (r.value) valueLine += `<div style="font-size:11px;color:#777;margin-top:3px">Value: ${escapeHtml(r.value)}</div>`;
  if (r.awardee) valueLine += `<div style="font-size:11px;color:#777;margin-top:2px">Awarded to: ${escapeHtml(r.awardee)}</div>`;
  const verifiedLine = r.verified_via
    ? `<details style="margin-top:6px;font-size:11px;color:#888;"><summary style="cursor:pointer;color:#888;">Verification</summary><div style="margin-top:4px;padding:6px 10px;background:#f7f4eb;border-radius:5px;line-height:1.5;">${escapeHtml(r.verified_via)}</div></details>`
    : "";
 
  // Priority flag for open opportunities with imminent deadlines, OR high-value watch
  const d = daysUntil(r.due);
  let priorityFlag = "";
  if (r.status === "open" && d != null && d >= 0 && d <= 30) priorityFlag = `<span class="priority-flag">Priority</span>`;
  else if (r.status === "watch" && r.expected_rfp) priorityFlag = `<span class="priority-flag" style="background:#8d5a14">Watch</span>`;
 
  const secondaryLink = r.secondary_url ? ` · <a href="${escapeHtml(r.secondary_url)}" target="_blank" rel="noopener" style="font-size:11px">alt source ↗</a>` : "";
 
  return `<tr>
    <td>
      <strong>${escapeHtml(r.title)}</strong>${priorityFlag}
      <div style="font-size:12px;color:#666;margin-top:4px">${escapeHtml(r.notes || "")}</div>
      ${valueLine}
      <div class="pillrow" style="margin-top:5px">${(r.keywords || []).map(k=>`<span class="pill pill-keyword">${escapeHtml(k)}</span>`).join(" ")}</div>
      ${verifiedLine}
    </td>
    <td>${escapeHtml(r.issuer)}<div style="font-size:11px;color:#888;margin-top:2px">${escapeHtml(r.state)} · <span class="pill pill-${escapeHtml(r.scope)}">${escapeHtml(r.scope)}</span></div></td>
    <td class="deadline-cell">${getDeadlineCell(r)}</td>
    <td><a href="${escapeHtml(r.url)}" target="_blank" rel="noopener">Open ↗</a>${secondaryLink}</td>
  </tr>`;
}
 
function renderStatusSection(rows, status, title, blurb) {
  if (!rows.length) return "";
  const headerCol = status === "open" ? "Deadline" : (status === "watch" ? "Expected timing" : (status === "awarded" ? "Awarded" : "Closed"));
  return `
    <div class="status-section ${status}-section">
      <div class="status-header ${status}">
        <h3>${title}</h3>
        <span class="badge">${rows.length}</span>
        <span class="blurb">${blurb}</span>
      </div>
    </div>
    <table>
      <thead><tr>
        <th>RFP</th>
        <th>Issuer / Jurisdiction</th>
        <th>${headerCol}</th>
        <th></th>
      </tr></thead>
      <tbody>${rows.map(rfpRow).join("")}</tbody>
    </table>
  `;
}
 
function panelRfps() {
  const q = prefs.q || "";
  const scope = prefs.scope || "all";
  const stateFilter = prefs.stateFilter || "all";
  const hideClosed = prefs.hideClosed !== false;
 
  const filtered = DATA.rfps.filter(r =>
    matchQuery([r.title, r.issuer, r.state, r.notes, (r.keywords||[]).join(" ")], q)
    && (scope === "all" || r.scope === scope || (scope === "county" && (r.scope === "county" || r.scope === "local")))
    && (stateFilter === "all" || r.state === stateFilter)
    && !(hideClosed && r.status === "closed")
  );
 
  const open = filtered.filter(r => r.status === "open").sort((a,b) => {
    const da = a.due ? new Date(a.due) : new Date(8640000000000000);
    const db = b.due ? new Date(b.due) : new Date(8640000000000000);
    return da - db;
  });
  const watch = filtered.filter(r => r.status === "watch").sort((a,b) => {
    const ka = a.expected_rfp || a.expected_rfi || "z";
    const kb = b.expected_rfp || b.expected_rfi || "z";
    return ka.localeCompare(kb);
  });
  const awarded = filtered.filter(r => r.status === "awarded").sort((a,b) => {
    const da = a.awarded_date || "0";
    const db = b.awarded_date || "0";
    return db.localeCompare(da);
  });
  const closed = filtered.filter(r => r.status === "closed");
 
  if (!filtered.length) return `<div class="empty">No RFPs match the current filters.</div>`;
 
  return [
    renderStatusSection(open, "open", "Open — accepting bids", "Active opportunities. Sorted by deadline (soonest first)."),
    renderStatusSection(watch, "watch", "Watch — forecast / planning", "RFI or RFP expected but not yet posted. Sorted by expected timing."),
    renderStatusSection(awarded, "awarded", "Awarded — competitive intel", "Recently awarded; useful for partnering or learning who's winning. Sorted by award date (newest first)."),
    renderStatusSection(closed, "closed", "Closed — historical reference", "Past RFPs no longer active. Useful for understanding precedent.")
  ].filter(Boolean).join("");
}
 
function panelPrograms() {
  const q = prefs.q || "";
  const list = DATA.programs.filter(p => matchQuery([p.name, p.state, p.note], q));
  if (!list.length) return `<div class="empty">No programs match.</div>`;
  return `
    <div class="status-section watch-section">
      <div class="status-header watch">
        <h3>State programs to watch</h3>
        <span class="badge">${list.length}</span>
        <span class="blurb">Active CIE / closed-loop referral initiatives where new procurements are most likely.</span>
      </div>
    </div>
    <div class="grid">
      ${list.map(p => `
        <div class="card">
          <h4><a href="${escapeHtml(p.url)}" target="_blank" rel="noopener">${escapeHtml(p.name)} ↗</a></h4>
          <div class="pillrow"><span class="pill pill-state">${escapeHtml(p.state)}</span></div>
          <div class="desc">${escapeHtml(p.note)}</div>
        </div>
      `).join("")}
    </div>`;
}
 
function panelPortals() {
  const q = prefs.q || "";
  const scope = prefs.scope || "all";
  const list = DATA.portals.filter(p =>
    matchQuery([p.name, p.state, p.desc], q)
    && (scope === "all" || p.scope === scope || (scope === "county" && (p.scope === "county" || p.scope === "local")))
  );
  if (!list.length) return `<div class="empty">No portals match.</div>`;
  return `
    <div class="status-section watch-section">
      <div class="status-header watch">
        <h3>Procurement portals to monitor</h3>
        <span class="badge">${list.length}</span>
        <span class="blurb">State and county procurement portals. The daily scan runs targeted searches across these.</span>
      </div>
    </div>
    <div class="grid">
      ${list.map(p => `
        <div class="card">
          <h4><a href="${escapeHtml(p.url)}" target="_blank" rel="noopener">${escapeHtml(p.name)} ↗</a></h4>
          <div class="pillrow"><span class="pill pill-${escapeHtml(p.scope)}">${escapeHtml(p.scope)}</span> <span class="pill pill-keyword">${escapeHtml(p.state)}</span></div>
          <div class="desc">${escapeHtml(p.desc)}</div>
        </div>
      `).join("")}
    </div>`;
}
 
function panelAggregators() {
  const q = prefs.q || "";
  const list = DATA.aggregators.filter(a => matchQuery([a.name, a.note], q));
  if (!list.length) return `<div class="empty">No aggregators match.</div>`;
  return `
    <div class="status-section watch-section">
      <div class="status-header watch">
        <h3>Aggregator quick-search links</h3>
        <span class="badge">${list.length}</span>
        <span class="blurb">Pre-filled searches across third-party RFP aggregators. Useful for catching small/local issuers.</span>
      </div>
    </div>
    <div class="quick-search-list">
      ${list.map(a => `
        <a class="qs" href="${escapeHtml(a.url)}" target="_blank" rel="noopener">
          <div class="label"><strong>${escapeHtml(a.name)}</strong><div class="meta">${escapeHtml(a.note)}</div></div>
          <div>↗</div>
        </a>
      `).join("")}
    </div>`;
}
 
function panelCbo() {
  const q = prefs.q || "";
  const scope = prefs.scope || "all";
  const list = DATA.cbo.filter(c =>
    matchQuery([c.name, c.state, c.desc], q)
    && (scope === "all" || c.scope === scope)
  );
  if (!list.length) return `<div class="empty">No funders match.</div>`;
  return `
    <div class="status-section watch-section">
      <div class="status-header watch">
        <h3>CBO funders &amp; intermediaries</h3>
        <span class="badge">${list.length}</span>
        <span class="blurb">Foundations, intermediaries, and CBO networks that issue or shape CIE / closed-loop referral procurement.</span>
      </div>
    </div>
    <div class="grid">
      ${list.map(c => `
        <div class="card">
          <h4><a href="${escapeHtml(c.url)}" target="_blank" rel="noopener">${escapeHtml(c.name)} ↗</a></h4>
          <div class="pillrow"><span class="pill pill-${escapeHtml(c.scope)}">${escapeHtml(c.scope)}</span> <span class="pill pill-keyword">${escapeHtml(c.state)}</span></div>
          <div class="desc">${escapeHtml(c.desc)}</div>
        </div>
      `).join("")}
    </div>`;
}
 
function populateStateFilter() {
  const states = [...new Set(DATA.rfps.map(r => r.state))].sort();
  const sel = document.getElementById("stateFilter");
  const current = prefs.stateFilter || "all";
  sel.innerHTML = `<option value="all">All states</option>` +
    states.map(s => `<option value="${escapeHtml(s)}"${current === s ? " selected" : ""}>${escapeHtml(s)}</option>`).join("");
}
 
function render() {
  document.getElementById("cnt-rfps").textContent = DATA.rfps.length;
  document.getElementById("cnt-programs").textContent = DATA.programs.length;
  document.getElementById("cnt-portals").textContent = DATA.portals.length;
  document.getElementById("cnt-agg").textContent = DATA.aggregators.length;
  document.getElementById("cnt-cbo").textContent = DATA.cbo.length;
 
